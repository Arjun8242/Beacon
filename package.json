{
  "name": "uptime-monitor-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:push": "pnpm --filter database db:push",
    "db:generate": "pnpm --filter database db:generate",
    "test": "vitest run"
  },
  "devDependencies": {
    "bcryptjs": "^3.0.3",
    "database": "workspace:^",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "prettier": "^3.0.0",
    "shared": "workspace:^",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@9.0.0"
}
