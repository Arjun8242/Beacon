# ─── Stage 1: Builder ─────────────────────────────────────────────────────────
FROM node:20-bookworm-slim AS builder

# Install system dependencies (Prisma needs openssl)
RUN apt-get update && apt-get install -y openssl ca-certificates && rm -rf /var/lib/apt/lists/*

# Install pnpm
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

WORKDIR /app

# Copy workspace manifests first (layer-cache friendly)
COPY pnpm-workspace.yaml ./
COPY pnpm-lock.yaml ./
COPY package.json ./

# Copy every package.json in the monorepo so pnpm can resolve the workspace graph
COPY apps/api/package.json          ./apps/api/
COPY apps/scheduler/package.json    ./apps/scheduler/
COPY apps/worker/package.json       ./apps/worker/
COPY apps/web/package.json          ./apps/web/
COPY packages/database/package.json ./packages/database/
COPY packages/queue/package.json    ./packages/queue/
COPY packages/shared/package.json   ./packages/shared/

# Install all dependencies (needed to compile workspace packages)
RUN pnpm install --frozen-lockfile

# Copy source code
COPY packages/ ./packages/
COPY apps/api/ ./apps/api/

# Generate Prisma client
RUN pnpm --filter database db:generate

# Build the API
RUN pnpm --filter api build

# ─── Stage 2: Production runner ───────────────────────────────────────────────
FROM node:20-bookworm-slim AS runner

# Install system dependencies (Prisma needs openssl)
RUN apt-get update && apt-get install -y openssl ca-certificates && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

WORKDIR /app

COPY pnpm-workspace.yaml ./
COPY pnpm-lock.yaml ./
COPY package.json ./

COPY apps/api/package.json          ./apps/api/
COPY apps/scheduler/package.json    ./apps/scheduler/
COPY apps/worker/package.json       ./apps/worker/
COPY apps/web/package.json          ./apps/web/
COPY packages/database/package.json ./packages/database/
COPY packages/queue/package.json    ./packages/queue/
COPY packages/shared/package.json   ./packages/shared/

# Production-only install
RUN pnpm install --frozen-lockfile --prod --ignore-scripts

# Copy compiled output and generated Prisma client from builder
COPY --from=builder /app/apps/api/dist          ./apps/api/dist
COPY --from=builder /app/packages/database      ./packages/database
COPY --from=builder /app/packages/shared        ./packages/shared
COPY --from=builder /app/packages/queue         ./packages/queue

# Prisma schema is needed by the client at runtime
COPY packages/database/prisma ./packages/database/prisma

ENV NODE_ENV=production

EXPOSE 3001

CMD ["node", "apps/api/dist/index.js"]
