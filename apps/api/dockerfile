# ─── Stage 1: Builder ─────────────────────────────────────────────────────────
FROM node:20-bookworm-slim AS builder

# Install system dependencies (Prisma needs openssl)
RUN apt-get update && apt-get install -y openssl ca-certificates && rm -rf /var/lib/apt/lists/*

# Install pnpm
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

WORKDIR /app

# Copy workspace manifests first (layer-cache friendly)
COPY pnpm-workspace.yaml ./
COPY pnpm-lock.yaml ./
COPY package.json ./

# Copy every package.json in the monorepo so pnpm can resolve the workspace graph
COPY apps/api/package.json          ./apps/api/
COPY apps/scheduler/package.json    ./apps/scheduler/
COPY apps/worker/package.json       ./apps/worker/
COPY apps/web/package.json          ./apps/web/
COPY packages/database/package.json ./packages/database/
COPY packages/queue/package.json    ./packages/queue/
COPY packages/shared/package.json   ./packages/shared/

# Install all dependencies (needed to compile workspace packages)
RUN pnpm install --frozen-lockfile

# Copy source code
COPY packages/ ./packages/
COPY apps/api/ ./apps/api/

# Generate Prisma client
RUN pnpm --filter database db:generate

# Build packages in dependency order (shared → queue → database → api)
# The ... suffix tells Turbo/pnpm to also build all local workspace dependencies
RUN pnpm --filter shared build
RUN pnpm --filter queue build
RUN pnpm --filter database build
RUN pnpm --filter api build

# ─── Stage 2: Production runner ───────────────────────────────────────────────
FROM node:20-bookworm-slim AS runner

# Install system dependencies (Prisma needs openssl)
RUN apt-get update && apt-get install -y openssl ca-certificates && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

WORKDIR /app

COPY pnpm-workspace.yaml ./
COPY pnpm-lock.yaml ./
COPY package.json ./

COPY apps/api/package.json          ./apps/api/
COPY apps/scheduler/package.json    ./apps/scheduler/
COPY apps/worker/package.json       ./apps/worker/
COPY apps/web/package.json          ./apps/web/
COPY packages/database/package.json ./packages/database/
COPY packages/queue/package.json    ./packages/queue/
COPY packages/shared/package.json   ./packages/shared/

# Production-only install
RUN pnpm install --frozen-lockfile --prod --ignore-scripts

# Copy compiled app dist
COPY --from=builder /app/apps/api/dist                               ./apps/api/dist

# Copy ONLY the compiled dist/ of each package (not src/)
COPY --from=builder /app/packages/shared/dist                        ./packages/shared/dist
COPY --from=builder /app/packages/queue/dist                         ./packages/queue/dist
COPY --from=builder /app/packages/database/dist                      ./packages/database/dist

# Copy pnpm virtual store which contains the Prisma generated client
# pnpm does NOT create per-package node_modules/.prisma; the client lives in the root .pnpm store
COPY --from=builder /app/node_modules/.pnpm                         ./node_modules/.pnpm

# Prisma schema is needed by the runtime query engine
COPY packages/database/prisma                                        ./packages/database/prisma

ENV NODE_ENV=production

EXPOSE 3001

CMD ["node", "apps/api/dist/index.js"]
